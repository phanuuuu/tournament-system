rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /matchPhotos/{matchId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /profilePhotos/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ภาพอวาตาลีค — เขียน Storage ได้แค่ signed-in (เหมือน matchPhotos) ส่วนการผูกรูปเข้ากับลีคจริง
    // (เขียน imageURL ใน Firestore) ยังจำกัดแค่แอดมินอยู่แล้วผ่าน firestore.rules
    // จำกัด 5MB (เท่า matchPhotos) เพราะโลโก้จากมือถือ/กล้องมักใหญ่กว่า 2MB ของรูปโปรไฟล์ทั่วไป
    match /leagueImages/{leagueId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
