rules_version = '2';

// เฟส 2: แยกข้อมูลส่วนตัว (users) ออกจากข้อมูลสาธารณะ (publicProfiles)
// ตามตารางการมองเห็นข้อมูลในสเปกข้อ 3
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // assign แอดมินคนแรกทำผ่าน Cloud Function (Admin SDK ข้าม rules) เท่านั้น
    match /meta/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // ข้อมูลส่วนตัว: ชื่อ, เบอร์, เฟซบุ๊ก, Line, role
    // เห็นได้แค่เจ้าของ + แอดมิน (เฟซบุ๊กที่คู่แข่งควรเห็น ผ่าน Cloud Function getOpponentContact เท่านั้น)
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'player';
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if false;
    }

    // ข้อมูลสาธารณะ: ชื่อที่ใช้แสดง + รูปโปรไฟล์ เท่านั้น เห็นได้ทุกคนที่ล็อกอิน
    // เขียนได้จาก Cloud Function เท่านั้น (mirror จาก users อัตโนมัติ)
    match /publicProfiles/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /leagues/{leagueId} {
      function isSelfJoin() {
        let before = resource.data.playerIds;
        let after = request.resource.data.playerIds;
        return resource.data.status == 'open'
          && after.size() == before.size() + 1
          && after.hasAll(before)
          && after.hasAny([request.auth.uid])
          && !before.hasAny([request.auth.uid])
          && after.size() <= resource.data.size;
      }

      function isSelfLeave() {
        let before = resource.data.playerIds;
        let after = request.resource.data.playerIds;
        return resource.data.status == 'open'
          && before.size() == after.size() + 1
          && before.hasAll(after)
          && before.hasAny([request.auth.uid])
          && !after.hasAny([request.auth.uid]);
      }

      allow read: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin() && resource.data.status != 'ongoing';
      allow update: if isAdmin() || ((isSelfJoin() || isSelfLeave())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerIds']));

      match /byeBans/{uid} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /matches/{matchId} {
      function isParticipant() {
        return isSignedIn() &&
          (request.auth.uid == resource.data.players.home || request.auth.uid == resource.data.players.away);
      }

      // ส่งผลของตัวเอง (สร้าง/แก้ไข) ได้จนกว่าผลจะอนุมัติ แก้ field อื่นไม่ได้
      function isValidSelfSubmission() {
        let before = resource.data;
        let after = request.resource.data;
        return before.status != 'approved'
          && after.diff(before).affectedKeys().hasOnly(['submissions', 'status'])
          && after.submissions.diff(before.submissions).affectedKeys().hasOnly([request.auth.uid]);
      }

      function submissionsMatch(a, b) {
        return a.scoreHome == b.scoreHome && a.scoreAway == b.scoreAway
          && a.get('penaltyHome', null) == b.get('penaltyHome', null)
          && a.get('penaltyAway', null) == b.get('penaltyAway', null);
      }

      // ผู้เล่นกดส่งผลแล้วบังเอิญตรงกับคู่แข่ง -> client เขียนอนุมัติอัตโนมัติได้เลย
      // (ต้องพิสูจน์ในตัว request ว่าสองฝั่งส่งตรงกันจริง ไม่ใช่เชื่อ client เปล่า ๆ)
      function isValidAutoApprove() {
        let before = resource.data;
        let after = request.resource.data;
        let home = before.players.home;
        let away = before.players.away;
        return before.status != 'approved'
          && after.diff(before).affectedKeys().hasOnly(['submissions', 'status', 'approvedResult'])
          && (home in after.submissions) && (away in after.submissions)
          && submissionsMatch(after.submissions[home], after.submissions[away])
          && after.status == 'approved'
          && after.approvedResult.decidedBy == 'auto';
      }

      allow read: if true;
      allow create: if isAdmin();
      // เฟส 9 ค่อยจำกัด resolve ข้อพิพาทของแอดมินให้ละเอียดขึ้น ตอนนี้แอดมินไว้ใจได้ (คนเดียวในระบบ)
      allow update: if isAdmin() || (isParticipant() && (isValidSelfSubmission() || isValidAutoApprove()));
      allow delete: if false;
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if false;
    }
  }
}
