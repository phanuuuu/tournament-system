rules_version = '2';

// เฟส 2: แยกข้อมูลส่วนตัว (users) ออกจากข้อมูลสาธารณะ (publicProfiles)
// ตามตารางการมองเห็นข้อมูลในสเปกข้อ 3
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // assign แอดมินคนแรกทำผ่าน Cloud Function (Admin SDK ข้าม rules) เท่านั้น
    match /meta/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // ข้อมูลส่วนตัว: ชื่อ, เบอร์, เฟซบุ๊ก, Line, role
    // เห็นได้แค่เจ้าของ + แอดมิน (เฟซบุ๊กที่คู่แข่งควรเห็น ผ่าน Cloud Function getOpponentContact เท่านั้น)
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'player';
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if false;
    }

    // ข้อมูลสาธารณะ: ชื่อที่ใช้แสดง + รูปโปรไฟล์ เท่านั้น เห็นได้ทุกคนที่ล็อกอิน
    // เขียนได้จาก Cloud Function เท่านั้น (mirror จาก users อัตโนมัติ)
    match /publicProfiles/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if isAdmin();

      match /byeBans/{uid} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if false;
    }
  }
}
